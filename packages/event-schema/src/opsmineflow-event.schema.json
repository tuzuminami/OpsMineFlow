{
  "$id": "opsmineflow-event.schema.json",
  "title": "OpsMineFlow Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "source",
    "source_event_id",
    "case_id",
    "session_id",
    "user_alias",
    "user_hash",
    "device_id",
    "app_name",
    "app_bundle_id",
    "window_title",
    "window_title_masked",
    "url",
    "url_masked",
    "domain",
    "activity_raw",
    "activity_normalized",
    "event_type",
    "timestamp_start",
    "timestamp_end",
    "duration_seconds",
    "idle_flag",
    "confidential_flag",
    "metadata_json",
    "created_at"
  ],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "source": { "type": "string" },
    "source_event_id": { "type": "string" },
    "case_id": { "type": "string" },
    "session_id": { "type": "string" },
    "user_alias": { "type": "string" },
    "user_hash": { "type": "string" },
    "device_id": { "type": "string" },
    "app_name": { "type": "string" },
    "app_bundle_id": { "type": "string" },
    "window_title": { "type": "string" },
    "window_title_masked": { "type": "string" },
    "url": { "type": "string" },
    "url_masked": { "type": "string" },
    "domain": { "type": "string" },
    "activity_raw": { "type": "string" },
    "activity_normalized": { "type": "string" },
    "event_type": { "type": "string" },
    "timestamp_start": { "type": "string", "format": "date-time" },
    "timestamp_end": { "type": "string", "format": "date-time" },
    "duration_seconds": { "type": "number", "minimum": 0 },
    "idle_flag": { "type": "boolean" },
    "confidential_flag": { "type": "boolean" },
    "metadata_json": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
